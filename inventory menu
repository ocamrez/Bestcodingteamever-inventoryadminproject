int main() {

    //INVENTORY MANAGEMENT data storage
	string productNames[100];
	double productPrices[100];
    int wellingtonStock[100];
    int christchurchStock[100];
    int aucklandStock[100];

    //EMPLOYEE MANAGEMENT
    string employeeNames[100];    //employee names
    string employeeStores[100];     //store locations
    

    //starting count for Inventory and Employee
    int productCount = 0;
    int employeeCount = 0;

    //menu selection storage
    int option;

	//MAIN MENU
	while (true) {
		cout << "\n----- Aotearoa Treasures Management System -----" << endl;
		cout << "1 - Product Management" << endl;
		cout << "2 - Employee Management" << endl;
		cout << "3 - Exit" << endl;
        cout << "Enter option" << endl;
		cin >> option;
		cin.ignore();


		//PRODUCT MANAGEMENT
		if (option == 1) {
			int productOption;
            while (true) {
        cout << "\n----- Product Management Menu -----" << endl;
        cout << "1 - View Products" << endl;
        cout << "2 - Add Product" << endl;
        cout << "3 - Update Product" << endl;
        cout << "4 - Delete Product" << endl;
        cout << "5 - Low Stock Alert" << endl;
        cout << "6 - Back to Main Menu" << endl;
        cout << "Enter option: ";
        cin >> productOption;
        cin.ignore();

		//VIEW PRODUCTS
        if (productOption == 1) {
            if (productCount == 0) {
                cout << "No products available." << endl;//when no products in stock => no products available
            }
            else {                                       //display table for all products
                cout << left << setw(5) << "No."
                     << setw(20) << "Product"
                     << setw(10) << "Price"
                     << setw(15) << "Wellington"
                     << setw(18) << "Christchurch"
                     << setw(15) << "Auckland" << endl;

                for (int i = 0; i < productCount; i++) {   //loop for picking out products
                    cout << left << setw(5) << i + 1
                         << setw(20) << productNames[i]
                         << "$" << setw(9) << productPrices[i]
                         << setw(15) << wellingtonStock[i]
                         << setw(18) << christchurchStock[i]
                         << setw(15) << aucklandStock[i] << endl;
                }
            }
        }

		//ADD PRODUCT
        else if (productOption == 2) {
            cout << "Enter product name: ";
            getline(cin, productNames[productCount]); //takes written line and stores in productNames[productCount]

            cout << "Enter product price: $";
            cin >> productPrices[productCount];

            cout << "Enter Wellington stock: ";
            cin >> wellingtonStock[productCount];

            cout << "Enter Christchurch stock: ";
            cin >> christchurchStock[productCount];

            cout << "Enter Auckland stock: ";
            cin >> aucklandStock[productCount];

            productCount++; //increase product count

            cout << "Product added successfully." << endl;
        }

		//UPDATE PRODUCT
        else if (productOption == 3) {
            int productNumber;

            cout << "Enter product number to update: ";
            cin >> productNumber;
            cin.ignore();

            if (productNumber < 1 || productNumber > productCount) {//invalid number check and notification
                cout << "Invalid product number." << endl;
            }
            else {
                int index = productNumber - 1; //array index for product data to give productNumber

                cout << "Enter new product name: ";
                getline(cin, productNames[index]);

                cout << "Enter new product price: $";
                cin >> productPrices[index];

                cout << "Enter new Wellington stock: ";
                cin >> wellingtonStock[index];

                cout << "Enter new Christchurch stock: ";
                cin >> christchurchStock[index];

                cout << "Enter new Auckland stock: ";
                cin >> aucklandStock[index];

                cout << "Product updated successfully." << endl;
            }
        }

		//DELETE PRODUCT
        else if (productOption == 4) {
            int productNumber;

            cout << "Enter product number to delete: ";
            cin >> productNumber;

            if (productNumber < 1 || productNumber > productCount) {
                cout << "Invalid product number." << endl;
            }
            else {
                int index = productNumber - 1;  //array index for product data to give productNumber

                for (int i = index; i < productCount - 1; i++) {  //removes product from ALL stores
                    productNames[i] = productNames[i + 1];
                    productPrices[i] = productPrices[i + 1];
                    wellingtonStock[i] = wellingtonStock[i + 1];
                    christchurchStock[i] = christchurchStock[i + 1];
                    aucklandStock[i] = aucklandStock[i + 1];
                }

                productCount--; //reduce product count

                cout << "Product deleted successfully." << endl;
            }
        }
		//LOW STOCK ALERT FEATURE
        else if (productOption == 5) {
            bool lowStockFound = false; // false = no low stock found, true = at least one low stock product found

            for (int i = 0; i < productCount; i++) { //loop for checking products
                if (wellingtonStock[i] < 5 || christchurchStock[i] < 5 || aucklandStock[i] < 5) {
                    lowStockFound = true;

                    cout << "\nLow stock product: " << productNames[i] << endl;

                    if (wellingtonStock[i] < 5) {
                        cout << "Wellington stock: " << wellingtonStock[i] << endl;
                    }

                    if (christchurchStock[i] < 5) {
                        cout << "Christchurch stock: " << christchurchStock[i] << endl;
                    }

                    if (aucklandStock[i] < 5) {
                        cout << "Auckland stock: " << aucklandStock[i] << endl;
                    }
                }
            }

            if (!lowStockFound) { //no low stock notification
                cout << "No low stock products found." << endl;
            }
        }
        else if (productOption == 6) {
            break;
        }
        else {
            cout << "Invalid choice." << endl;
        }
    }
}
       
